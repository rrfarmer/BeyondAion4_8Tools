HOST=127.0.0.1
PORT=3000
SESSION_SECRET=replace-with-a-long-random-string-before-sharing

# Optional. If set, registration requires this code.
PORTAL_REGISTRATION_CODE=

# The portal reads static item names from this repo if available.
AION_REPO_ROOT=C:\Users\ryanf\Documents\GitHub\aion-server

# Local portal storage. Users and sessions are separate from Aion passwords.
DATA_DIR=./data

# Used only by the manual icon cache warmer. The running web app never fetches Codex live.
AION_CODEX_BASE_URL=https://aioncodex.com/us

LOGIN_DB_HOST=127.0.0.1
LOGIN_DB_PORT=3307
LOGIN_DB_USER=root
LOGIN_DB_PASSWORD=aion
LOGIN_DB_NAME=aion_ls

GAME_DB_HOST=127.0.0.1
GAME_DB_PORT=3307
GAME_DB_USER=root
GAME_DB_PASSWORD=aion
GAME_DB_NAME=aion_gs

# Game server admin endpoint. The portal sends express mail through the LIVE game server (via
# SystemMailService) so online recipients get an instant bell + icon. Inside docker use the internal
# service name (http://gameserver:7780). The token MUST match the game server's ADMIN_API_TOKEN.
GAME_SERVER_ADMIN_URL=http://gameserver:7780
GAME_SERVER_ADMIN_TOKEN=change-me-admin-token
